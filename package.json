{
  "name": "yourbud",
  "version": "0.1.0",
  "description": "A modular autonomous-ish AI agent starter by Bud",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:web": "APP_MODE=web tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:web": "APP_MODE=web node dist/index.js",
    "test": "npm run test:unit && npm run test:smoke",
    "test:unit": "tsx --test test/**/*.test.ts",
    "test:smoke": "node test/smoke.mjs",
    "smoke:cli": "node test/cli-smoke.mjs",
    "bench": "npm run build && node test/benchmarks.mjs"
  },
  "dependencies": {
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
