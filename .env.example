AGENT_NAME=Bud
AGENT_MISSION=Be useful, fast, and honest.
MAX_TURNS_PER_RUN=4
AUTO_LEARN_INTERVAL=6

# Brain provider: auto | openclaw | openai
BRAIN_PROVIDER=openclaw

# OpenClaw brain adapter settings
OPENCLAW_AGENT_ID=main
OPENCLAW_THINKING=low
OPENCLAW_TIMEOUT_MS=90000

# Optional OpenAI API brain (used when BRAIN_PROVIDER=openai or auto+key exists)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=openai-codex/gpt-5.3-codex
